<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Заказ оформлен — LTLLMND</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
    <main class="main-content">
        <section class="section container">
            <div class="success-page">
                <div class="success-icon"><span class="material-icons-outlined">check_circle</span></div>
                <h1>Заказ оформлен!</h1>
                <p class="success-order-number">Номер заказа: <strong><%= order.order_number %></strong></p>
                <p>Мы свяжемся с вами по email <strong><%= order.customer_email %></strong> для подтверждения.</p>
                <div class="success-details">
                    <h3>Детали заказа</h3>
                    <% order.items.forEach(function(item) { %>
                    <div class="summary-item">
                        <span><%= item.product_name %> <% if(item.size){%>(<%= item.size %>)<%}%> × <%= item.quantity %></span>
                        <span><%= formatPrice(item.price * item.quantity) %> ₽</span>
                    </div>
                    <% }); %>
                    <div class="summary-total"><span>Итого</span><span><%= formatPrice(order.total_price) %> ₽</span></div>
                </div>
                <a href="/catalog" class="btn btn-black">Продолжить покупки</a>
            </div>
        </section>
    </main>
    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>