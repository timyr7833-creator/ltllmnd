<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> — LTLLMND</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
    <main class="main-content">
        <section class="section container">
            <div class="product-detail">
                <div class="product-gallery">
                    <div class="product-main-image">
                        <img id="main-product-image"
                             src="/uploads/<%= product.main_image || '' %>"
                             alt="<%= product.name %>"
                             onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22600%22 height=%22800%22><rect fill=%22%23f0f0f0%22 width=%22600%22 height=%22800%22/><text x=%2250%%25%22 y=%2250%%25%22 text-anchor=%22middle%22 fill=%22%23999%22 font-size=%2220%22>LTLLMND</text></svg>'">
                    </div>
                    <% if (product.images && product.images.length > 1) { %>
                    <div class="product-thumbnails">
                        <% product.images.forEach(function(img) { %>
                        <img src="/uploads/<%= img.filename %>"
                             alt="Фото"
                             class="thumbnail <%= img.is_main ? 'active' : '' %>"
                             onclick="changeImage(this, '/uploads/<%= img.filename %>')"
                             onerror="this.style.display='none'">
                        <% }); %>
                    </div>
                    <% } %>
                </div>

                <div class="product-info">
                    <h1 class="product-title"><%= product.name %></h1>
                    <div class="product-price-block">
                        <span class="product-price"><%= formatPrice(product.price) %> ₽</span>
                        <% if (product.old_price) { %>
                        <span class="product-old-price"><%= formatPrice(product.old_price) %> ₽</span>
                        <% } %>
                    </div>

                    <form method="POST" action="/cart/add" class="product-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="productId" value="<%= product.id %>">

                        <% if (product.sizes) { %>
                        <% var sizesList = product.sizes.split(',').map(function(s){return s.trim()}); %>
                        <div class="form-group">
                            <label class="form-label">Размер</label>
                            <div class="size-selector">
                                <% sizesList.forEach(function(size, i) { %>
                                <label class="size-option">
                                    <input type="radio" name="size" value="<%= size %>" <%= i===0?'checked':'' %> required>
                                    <span><%= size %></span>
                                </label>
                                <% }); %>
                            </div>
                        </div>
                        <% } %>

                        <div class="form-group">
                            <label class="form-label">Количество</label>
                            <div class="quantity-selector">
                                <button type="button" class="qty-btn" onclick="changeQty(-1)">−</button>
                                <input type="number" name="quantity" id="qty-input" value="1" min="1" max="10">
                                <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-black btn-full add-to-cart-btn">
                            <span class="material-icons-outlined">shopping_bag</span>
                            Добавить в корзину
                        </button>
                    </form>

                    <% if (product.description) { %>
                    <div class="product-description">
                        <h3>Описание</h3>
                        <p><%= product.description %></p>
                    </div>
                    <% } %>

                    <div class="product-details-accordion">
                        <details>
                            <summary>Доставка</summary>
                            <p>Бесплатная доставка СДЭК по России при заказе от 10 000 ₽. Срок: 2-7 рабочих дней.</p>
                        </details>
                        <details>
                            <summary>Возврат и обмен</summary>
                            <p>Возврат в течение 14 дней с момента получения. Товар должен быть в оригинальном состоянии с бирками.</p>
                        </details>
                    </div>
                </div>
            </div>

            <!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> — LTLLMND</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
    <main class="main-content">
        <section class="section container">
            <div class="product-detail">
                <div class="product-gallery">
                    <%
                        // Универсальная функция: если URL — оставляем как есть, иначе — добавляем /uploads/
                        function imgUrl(filename) {
                            if (!filename) return '';
                            return filename.startsWith('http') ? filename : '/uploads/' + filename;
                        }
                    %>
                    <div class="product-main-image">
                        <img id="main-product-image"
                             src="<%= imgUrl(product.main_image) %>"
                             alt="<%= product.name %>"
                             onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22600%22 height=%22800%22><rect fill=%22%23f0f0f0%22 width=%22600%22 height=%22800%22/><text x=%2250%%25%22 y=%2250%%25%22 text-anchor=%22middle%22 fill=%22%23999%22 font-size=%2220%22>LTLLMND</text></svg>'">
                    </div>
                    <% if (product.images && product.images.length > 1) { %>
                    <div class="product-thumbnails">
                        <% product.images.forEach(function(img) { %>
                        <img src="<%= imgUrl(img.filename) %>"
                             alt="Фото"
                             class="thumbnail <%= img.is_main ? 'active' : '' %>"
                             onclick="changeImage(this, '<%= imgUrl(img.filename) %>')"
                             onerror="this.style.display='none'">
                        <% }); %>
                    </div>
                    <% } %>
                </div>

                <div class="product-info">
                    <h1 class="product-title"><%= product.name %></h1>
                    <div class="product-price-block">
                        <span class="product-price"><%= formatPrice(product.price) %> ₽</span>
                        <% if (product.old_price) { %>
                        <span class="product-old-price"><%= formatPrice(product.old_price) %> ₽</span>
                        <% } %>
                    </div>

                    <form method="POST" action="/cart/add" class="product-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="productId" value="<%= product.id %>">

                        <% if (product.sizes) { %>
                        <% var sizesList = product.sizes.split(',').map(function(s){return s.trim()}); %>
                        <div class="form-group">
                            <label class="form-label">Размер</label>
                            <div class="size-selector">
                                <% sizesList.forEach(function(size, i) { %>
                                <label class="size-option">
                                    <input type="radio" name="size" value="<%= size %>" <%= i===0?'checked':'' %> required>
                                    <span><%= size %></span>
                                </label>
                                <% }); %>
                            </div>
                        </div>
                        <% } %>

                        <div class="form-group">
                            <label class="form-label">Количество</label>
                            <div class="quantity-selector">
                                <button type="button" class="qty-btn" onclick="changeQty(-1)">−</button>
                                <input type="number" name="quantity" id="qty-input" value="1" min="1" max="10">
                                <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-black btn-full add-to-cart-btn">
                            <span class="material-icons-outlined">shopping_bag</span>
                            Добавить в корзину
                        </button>
                    </form>

                    <% if (product.description) { %>
                    <div class="product-description">
                        <h3>Описание</h3>
                        <p><%= product.description %></p>
                    </div>
                    <% } %>

                    <div class="product-details-accordion">
                        <details>
                            <summary>Доставка</summary>
                            <p>Бесплатная доставка СДЭК по России при заказе от 10 000 ₽. Срок: 2-7 рабочих дней.</p>
                        </details>
                        <details>
                            <summary>Возврат и обмен</summary>
                            <p>Возврат в течение 14 дней с момента получения. Товар должен быть в оригинальном состоянии с бирками.</p>
                        </details>
                    </div>
                </div>
            </div>

            <% if (related.length > 0) { %>
            <div class="related-section">
                <h2 class="section-title">Вам также может понравиться</h2>
                <div class="products-grid">
                    <% related.forEach(function(p) { %>
                    <a href="/product/<%= p.slug %>" class="product-card">
                        <div class="product-card-image">
                            <img src="<%= imgUrl(p.main_image) %>" alt="<%= p.name %>"
                                 onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22500%22><rect fill=%22%23f0f0f0%22 width=%22400%22 height=%22500%22/></svg>'">
                        </div>
                        <div class="product-card-info">
                            <h3><%= p.name %></h3>
                            <span class="price"><%= formatPrice(p.price) %> ₽</span>
                        </div>
                    </a>
                    <% }); %>
                </div>
            </div>
            <% } %>
        </section>
    </main>
    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
    <script>
    function changeImage(thumb, src) {
        document.getElementById('main-product-image').src = src;
        document.querySelectorAll('.thumbnail').forEach(function(t){t.classList.remove('active')});
        thumb.classList.add('active');
    }
    function changeQty(d) {
        var inp = document.getElementById('qty-input');
        var v = parseInt(inp.value)+d;
        if(v<1)v=1; if(v>10)v=10;
        inp.value=v;
    }
    </script>
</body>
</html>